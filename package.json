{
  "name": "@toma.com/vad",
  "version": "1.0.2",
  "description": "Embeddable real-time Voice Activity Detection (Silero v5) and End-of-Turn detection. Bring your own local ONNX models.",
  "type": "module",
  "license": "MIT",
  "author": "Toma (https://toma.com)",
  "contributors": [
    "Anthony Krivonos (https://github.com/anthonykrivonos)",
    "Ray Huang (https://github.com/ray-cj-huang)"
  ],
  "keywords": [
    "vad",
    "voice-activity-detection",
    "end-of-turn",
    "silero",
    "onnx",
    "speech"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toma-so/vad.git"
  },
  "homepage": "https://github.com/toma-so/vad#readme",
  "bugs": {
    "url": "https://github.com/toma-so/vad/issues"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.3.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf dist node_modules *.tsbuildinfo",
    "prepublishOnly": "bun run build",
    "release": "gh release create v$npm_package_version --generate-notes"
  },
  "resolutions": {
    "onnxruntime-node": "1.22.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.5.0",
    "async-mutex": "^0.5.0",
    "lodash": "^4.17.21",
    "onnxruntime-node": "1.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bun": "1.3.13",
    "@types/lodash": "^4.17.4",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  },
  "trustedDependencies": [
    "onnxruntime-node",
    "protobufjs"
  ]
}
